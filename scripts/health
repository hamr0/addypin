#!/bin/bash

# AddyPin Health Check Script
# Comprehensive health monitoring for production deployment

# Configuration
HEALTH_CHECK_URL="https://addypin.com"
API_STATS_URL="https://addypin.com/api/stats"
API_HEALTH_URL="https://addypin.com/api/health"
LOG_FILE="/var/log/addypin/health-check-$(date '+%Y%m%d').log"
TIMEOUT=10
MAX_RESPONSE_TIME=5

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Logging function
log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

# Status function with colors
status() {
    local level=$1
    local message=$2
    
    case $level in
        "SUCCESS")
            echo -e "${GREEN}✅ $message${NC}"
            log "SUCCESS: $message"
            ;;
        "WARNING")
            echo -e "${YELLOW}⚠️ $message${NC}"
            log "WARNING: $message"
            ;;
        "ERROR")
            echo -e "${RED}❌ $message${NC}"
            log "ERROR: $message"
            ;;
        "INFO")
            echo -e "ℹ️ $message"
            log "INFO: $message"
            ;;
    esac
}

# Service health check
check_service_status() {
    status "INFO" "Checking systemd service status..."
    
    if systemctl is-active --quiet addypin; then
        status "SUCCESS" "AddyPin service is running"
        
        # Get detailed service info
        local pid=$(systemctl show addypin -p MainPID --value)
        local memory=$(ps -p $pid -o %mem --no-headers 2>/dev/null | xargs)
        local cpu=$(ps -p $pid -o %cpu --no-headers 2>/dev/null | xargs)
        
        status "INFO" "Process ID: $pid"
        status "INFO" "Memory usage: ${memory}%"
        status "INFO" "CPU usage: ${cpu}%"
        
        # Check if memory usage is concerning
        if [ "$(echo "$memory > 15" | bc 2>/dev/null)" -eq 1 ]; then
            status "WARNING" "High memory usage detected"
        fi
        
        return 0
    else
        status "ERROR" "AddyPin service is not running"
        return 1
    fi
}

# Database connectivity check
check_database() {
    status "INFO" "Checking database connectivity..."
    
    if systemctl is-active --quiet postgresql; then
        status "SUCCESS" "PostgreSQL service is running"
        
        # Test database connection
        if sudo -u postgres psql -d addypin -c "SELECT 1;" > /dev/null 2>&1; then
            status "SUCCESS" "Database connection successful"
            
            # Get database size
            local db_size=$(sudo -u postgres psql -d addypin -t -c "SELECT pg_size_pretty(pg_database_size('addypin'));" 2>/dev/null | xargs)
            status "INFO" "Database size: $db_size"
            
            return 0
        else
            status "ERROR" "Database connection failed"
            return 1
        fi
    else
        status "ERROR" "PostgreSQL service is not running"
        return 1
    fi
}

# Development environment check
check_development_environment() {
    status "INFO" "Checking development environment..."
    
    # Check for SSH tunnels
    local tunnel_count=$(ps aux | grep -v grep | grep "ssh.*155.94.144.191.*5432" | wc -l)
    
    if [ $tunnel_count -gt 0 ]; then
        status "INFO" "SSH tunnels detected: $tunnel_count active"
        
        # Test tunnel connectivity
        if nc -z localhost 5432 2>/dev/null; then
            status "SUCCESS" "SSH tunnel connectivity verified"
        else
            status "WARNING" "SSH tunnel processes exist but port not accessible"
        fi
    else
        status "INFO" "No SSH tunnels detected (normal for production-only mode)"
    fi
}

# HTTP endpoint checks
check_http_endpoints() {
    status "INFO" "Checking HTTP endpoints..."
    
    local failed_checks=0
    local total_checks=0
    
    # Main page check
    status "INFO" "Testing main page: $HEALTH_CHECK_URL"
    local start_time=$(date +%s.%N)
    if curl -f -s --max-time $TIMEOUT "$HEALTH_CHECK_URL" > /dev/null 2>&1; then
        local end_time=$(date +%s.%N)
        local response_time=$(echo "$end_time - $start_time" | bc -l)
        status "SUCCESS" "Main page accessible (${response_time}s)"
    else
        status "ERROR" "Main page not accessible"
        ((failed_checks++))
    fi
    ((total_checks++))
    
    # API stats check
    status "INFO" "Testing API stats: $API_STATS_URL"
    local start_time=$(date +%s.%N)
    if curl -f -s --max-time $TIMEOUT "$API_STATS_URL" > /dev/null 2>&1; then
        local end_time=$(date +%s.%N)
        local response_time=$(echo "$end_time - $start_time" | bc -l)
        status "SUCCESS" "API stats endpoint accessible (${response_time}s)"
    else
        status "ERROR" "API stats endpoint not accessible"
        ((failed_checks++))
    fi
    ((total_checks++))
    
    # API health check
    status "INFO" "Testing API health: $API_HEALTH_URL"
    if curl -f -s --max-time $TIMEOUT "$API_HEALTH_URL" > /dev/null 2>&1; then
        status "SUCCESS" "API health endpoint accessible"
    else
        status "ERROR" "API health endpoint not accessible"
        ((failed_checks++))
    fi
    ((total_checks++))
    
    local passed_checks=$((total_checks - failed_checks))
    status "INFO" "HTTP endpoint checks: $passed_checks/$total_checks passed"
    
    if [ $failed_checks -eq 0 ]; then
        return 0
    else
        return 1
    fi
}

# SSL certificate check
check_ssl_certificate() {
    status "INFO" "Checking SSL certificate..."
    
    local cert_info=$(echo | openssl s_client -servername addypin.com -connect addypin.com:443 2>/dev/null | openssl x509 -noout -dates 2>/dev/null)
    
    if [ $? -eq 0 ]; then
        status "SUCCESS" "SSL certificate is valid"
        
        local expiry_date=$(echo "$cert_info" | grep notAfter | cut -d= -f2)
        status "INFO" "Certificate expires on: $expiry_date"
        
        # Calculate days until expiry
        local expiry_epoch=$(date -d "$expiry_date" +%s 2>/dev/null)
        local current_epoch=$(date +%s)
        local days_until_expiry=$(( (expiry_epoch - current_epoch) / 86400 ))
        
        status "INFO" "Days until expiry: $days_until_expiry"
        
        if [ $days_until_expiry -lt 30 ]; then
            status "WARNING" "SSL certificate expires in less than 30 days"
        fi
        
        return 0
    else
        status "ERROR" "SSL certificate check failed"
        return 1
    fi
}

# System resource check
check_system_resources() {
    status "INFO" "Checking system resources..."
    
    # Disk usage
    local disk_usage=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
    status "INFO" "Disk usage: ${disk_usage}%"
    
    if [ $disk_usage -lt 85 ]; then
        status "SUCCESS" "Disk usage is normal"
    elif [ $disk_usage -lt 95 ]; then
        status "WARNING" "Disk usage is high"
        return 1
    else
        status "ERROR" "Disk usage is critical"
        return 1
    fi
    
    # Memory usage
    local mem_total=$(free | grep '^Mem:' | awk '{print $2}')
    local mem_used=$(free | grep '^Mem:' | awk '{print $3}')
    local mem_percent=$(echo "scale=0; $mem_used * 100 / $mem_total" | bc)
    
    status "INFO" "Memory usage: ${mem_percent}%"
    
    if [ $mem_percent -lt 80 ]; then
        status "SUCCESS" "Memory usage is normal"
    elif [ $mem_percent -lt 90 ]; then
        status "WARNING" "Memory usage is high"
    else
        status "ERROR" "Memory usage is critical"
        return 1
    fi
    
    return 0
}

# Log analysis
check_recent_logs() {
    status "INFO" "Checking recent logs for errors..."
    
    local error_count=0
    local warning_count=0
    
    # Check various log files for errors in the last hour
    if [ -f /var/log/syslog ]; then
        error_count=$(grep -c "$(date -d '1 hour ago' '+%b %d %H').*ERROR\|$(date '+%b %d %H').*ERROR" /var/log/syslog 2>/dev/null || echo 0)
        warning_count=$(grep -c "$(date -d '1 hour ago' '+%b %d %H').*WARNING\|$(date '+%b %d %H').*WARNING" /var/log/syslog 2>/dev/null || echo 0)
    fi
    
    status "INFO" "Errors in last hour: $error_count"
    status "INFO" "Warnings in last hour: $warning_count"
    
    if [ $error_count -eq 0 ] && [ $warning_count -eq 0 ]; then
        status "SUCCESS" "No errors found in recent logs"
        return 0
    elif [ $error_count -eq 0 ] && [ $warning_count -gt 0 ]; then
        status "WARNING" "Warnings found in recent logs"
        return 1
    else
        status "ERROR" "Errors found in recent logs"
        return 1
    fi
}

# Main execution
main() {
    echo "🏥 AddyPin Health Check - $(date)"
    echo "=================================="
    log "Starting health check"
    
    local overall_status=0
    local failed_checks=()
    
    # Create log directory if it doesn't exist
    mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
    
    # Run all checks
    if ! check_service_status; then
        failed_checks+=("Service Status")
        overall_status=1
    fi
    
    echo ""
    if ! check_database; then
        failed_checks+=("Database")
        overall_status=1
    fi
    
    echo ""
    check_development_environment
    
    echo ""
    if ! check_http_endpoints; then
        failed_checks+=("HTTP Endpoints")
        overall_status=1
    fi
    
    echo ""
    if ! check_ssl_certificate; then
        failed_checks+=("SSL Certificate")
        overall_status=1
    fi
    
    echo ""
    if ! check_system_resources; then
        failed_checks+=("System Resources")
        overall_status=1
    fi
    
    echo ""
    if ! check_recent_logs; then
        failed_checks+=("Log Analysis")
        # Don't fail overall status for log warnings
    fi
    
    echo ""
    echo "=================================="
    
    if [ $overall_status -eq 0 ]; then
        status "SUCCESS" "All health checks passed"
        log "Health check completed successfully"
    else
        status "ERROR" "Some health checks failed - Investigation required"
        log "Health check completed with failures: ${failed_checks[*]}"
    fi
    
    log "Health check completed with status: $overall_status"
    exit $overall_status
}

# Run main function
main "$@"