# AddyPin MSMTP Configuration Template
# Location: /root/.msmtprc
# Permissions: chmod 600 /root/.msmtprc (CRITICAL!)

# Set default values for all accounts
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-bundle.crt
logfile        ~/.msmtp.log

# Gmail configuration for AddyPin
account        gmail
host           smtp.gmail.com
port           587
from           YOUR_GMAIL_ADDRESS@gmail.com
user           YOUR_GMAIL_ADDRESS@gmail.com
password       YOUR_16_DIGIT_APP_PASSWORD

# Set default account to use
account default : gmail

# Instructions:
# 1. Replace YOUR_GMAIL_ADDRESS@gmail.com with your actual Gmail address
# 2. Replace YOUR_16_DIGIT_APP_PASSWORD with your Gmail App Password
# 3. Get App Password from: https://myaccount.google.com/apppasswords
# 4. Ensure 2-Factor Authentication is enabled on Gmail first
# 5. Save this file as /root/.msmtprc
# 6. Set secure permissions: chmod 600 /root/.msmtprc