# addypin v2 — runtime configuration.
# Copy to `.env`, fill in real values, never commit.
#
# Generate each 32-byte secret with:
#   openssl rand -hex 32

# AES-256-GCM key for encrypting pin coordinates at rest.
# Compromise means all stored coords are decryptable. Keep out of backups.
ADDYPIN_DATA_KEY=

# HMAC-SHA256 key for email fingerprints (owner lookup).
# Compromise alone does not expose any email — but combined with a DB
# leak, an attacker can test "is email X in the DB?" via HMAC guessing.
ADDYPIN_EMAIL_KEY=

# HMAC-SHA256 key for signed magic-link tokens and session cookies.
# Rotation invalidates all outstanding tokens and active sessions.
ADDYPIN_SIGNING_KEY=

# HTTP port. nginx proxies https://addypin.com → http://127.0.0.1:${PORT}
PORT=3000

# Interface to bind. Defaults to 127.0.0.1 (loopback only) so the Node
# process is reachable solely via the local nginx reverse proxy — which
# is what makes trusting the X-Forwarded-For header for rate-limit keying
# safe. Set HOST=0.0.0.0 ONLY if you knowingly expose the port directly
# (e.g. LAN/device testing); a remote client can then spoof XFF.
HOST=127.0.0.1

# SQLite file lives here. Directory is created on first run.
DATA_DIR=./data

# Public-facing base URL used to build email links (e.g. confirmation
# magic links). Production: https://addypin.com. If unset, the server
# falls back to the request's own scheme + Host header — fine for
# localhost dev but ambiguous behind some proxies.
BASE_URL=

# SMTP identity for outbound mail via msmtp.
# Reuses the system-level Postfix submission port on localhost.
MAIL_FROM_ADDRESS=noreply@addypin.com
MAIL_FROM_NAME=addypin
