# Database Configuration
# Dev (SSH tunnel): postgresql://addypin_user:PASSWORD@localhost:5432/addypin_dev
# Staging: postgresql://addypin_user:PASSWORD@localhost:5432/addypin_staging
# Production: postgresql://addypin_user:PASSWORD@localhost:5432/addypin
DATABASE_URL=postgresql://user:password@host:5432/database

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Authentication (Clerk)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
WEBHOOK_SECRET=your_webhook_secret_here

# Analytics (Umami)
UMAMI_API_URL=https://api.umami.is
UMAMI_WEBSITE_ID=your_umami_website_id

# Environment
NODE_ENV=development

# Optional: Port (default: 5000 in dev, 3000 in prod)
PORT=5000
