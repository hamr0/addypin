{
  "name": "addypin",
  "version": "2.0.13",
  "private": true,
  "type": "module",
  "description": "Location sharing via short links. v2 rewrite.",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --experimental-sqlite server/main.js",
    "dev": "node --experimental-sqlite --watch server/main.js",
    "test": "node --experimental-sqlite --test --test-reporter=spec \"server/**/*.test.js\"",
    "stats": "node --experimental-sqlite server/stats.js",
    "stats:log": "node --experimental-sqlite server/stats.js --watch 600"
  },
  "dependencies": {
    "knowless": "^1.1.6"
  }
}
